@model GestorDeApartamentos.Model.Apartamento

<h2>Alquilar Apartamento</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        @TempData["Mensaje"]
    </div>
}

<form asp-action="Alquilar" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="IdentificacionInquilino" class="form-label"></label>
        <input asp-for="IdentificacionInquilino" class="form-control" placeholder="Ingrese la cédula del inquilino" required />
        <span asp-validation-for="IdentificacionInquilino" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="NombreInquilino" class="form-label"></label>
        <input asp-for="NombreInquilino" class="form-control" placeholder="Ingrese el nombre completo" required />
        <span asp-validation-for="NombreInquilino" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="FechaInicioAlquiler" class="form-label"></label>
        <input asp-for="FechaInicioAlquiler" type="date" class="form-control" required />
        <span asp-validation-for="FechaInicioAlquiler" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CantidadDeMesesAlquiler" class="form-label"></label>
        <input asp-for="CantidadDeMesesAlquiler" type="number" class="form-control" placeholder="Ejemplo: 12" required />
        <span asp-validation-for="CantidadDeMesesAlquiler" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Confirmar Alquiler</button>
    <a asp-action="Disponibles" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
