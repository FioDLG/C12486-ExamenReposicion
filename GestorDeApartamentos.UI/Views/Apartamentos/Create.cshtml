@model GestorDeApartamentos.Model.Apartamento

<h2>Agregar Apartamento</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label>Nombre</label>
        <input asp-for="Nombre" class="form-control" />
    </div>
    <div class="form-group">
        <label>Descripción</label>
        <input asp-for="Descripcion" class="form-control" />
    </div>
    <div class="form-group">
        <label>Número de Piso</label>
        <input asp-for="NumeroDePiso" class="form-control" />
    </div>
    <div class="form-group">
        <label>Precio por Mes</label>
        <input asp-for="PrecioPorMes" class="form-control" />
    </div>
    <button type="submit" class="btn btn-success">Guardar</button>
</form>

