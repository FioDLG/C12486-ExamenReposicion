@model IEnumerable<GestorDeApartamentos.Model.Apartamento>

<h2>Lista de Apartamentos</h2>

<form method="get" class="mb-3">
    <div class="row">
        <div class="col-md-4">
            <input type="text" name="nombre" class="form-control" placeholder="Buscar por nombre" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">Buscar</button>
        </div>
    </div>
</form>


<table class="table">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Estado</th>
            <th>Piso</th>
            <th>Precio por mes</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var apto in Model)
        {
            <tr>
                <td>@apto.Nombre</td>
                <td>@apto.Estado</td>
                <td>@apto.NumeroDePiso</td>
                <td>@apto.PrecioPorMes</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@apto.Id">Editar</a> |
                    <a asp-action="Detalle" asp-route-id="@apto.Id">Detalle</a>
                </td>
            </tr>
        }
    </tbody>
</table>


